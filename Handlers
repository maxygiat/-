import logging
from aiogram import Router, F, Bot
from aiogram.filters import Command
from aiogram.types import Message, CallbackQuery
from aiogram.fsm.context import FSMContext
from aiogram.fsm.state import State, StatesGroup

from config import Config
from post_manager import (
    create_and_send_post,
    publish_to_channel,
    pending_posts,
    get_preview_keyboard,
)
from ai_generator import generate_vpn_news

logger = logging.getLogger(__name__)
router = Router()

# Load config once for use in handlers
_config: Config | None = None


def get_config() -> Config:
    global _config
    if _config is None:
        _config = Config()
    return _config


class EditState(StatesGroup):
    waiting_for_text = State()


def is_admin(user_id: int) -> bool:
    return user_id in get_config().ADMIN_IDS


# ─── /start ───────────────────────────────────────────────────────────────────

@router.message(Command("start"))
async def cmd_start(message: Message):
    if not is_admin(message.from_user.id):
        return

    config = get_config()
    await message.answer(
        "🤖 <b>Titul VPN — Новостной бот</b>\n\n"
        "Я автоматически генерирую VPN-новости с помощью ИИ "
        f"и публикую их в канал каждые <b>{config.POST_INTERVAL_HOURS} ч.</b>\n\n"
        "📋 <b>Команды:</b>\n"
        "/post — создать пост прямо сейчас\n"
        "/status — статус бота\n"
        "/autopublish — вкл/выкл превью перед публикацией\n"
        "/interval — изменить интервал постинга\n"
        "/help — справка",
        parse_mode="HTML"
    )


