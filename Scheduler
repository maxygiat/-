import logging
from apscheduler.schedulers.asyncio import AsyncIOScheduler
from aiogram import Bot

from config import Config
from post_manager import create_and_send_post

logger = logging.getLogger(__name__)


def setup_scheduler(scheduler: AsyncIOScheduler, bot: Bot, config: Config):
    """Set up the posting schedule."""
    interval_minutes = int(config.POST_INTERVAL_HOURS * 60)

    scheduler.add_job(
        create_and_send_post,
        trigger="interval",
        minutes=interval_minutes,
        args=[bot, config],
        id="auto_post",
        name=f"Auto VPN news post every {config.POST_INTERVAL_HOURS}h",
        misfire_grace_time=300,  # 5 min grace period
    )

    logger.info(
        "📅 Расписание настроено: каждые %d минут (%.1f ч.)",
        interval_minutes,
        config.POST_INTERVAL_HOURS
    )
