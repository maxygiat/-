# ──────────────────────────────────────────────
# Titul VPN News Bot — конфигурация
# ──────────────────────────────────────────────

# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# API ключ Anthropic (Claude AI)
# Получить: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ID канала: @username или числовой ID вида -100xxxxxxxxxx
# Бот должен быть администратором канала!
CHANNEL_ID=@TitulVPN

# Твой Telegram user ID (можно узнать через @userinfobot)
# Несколько ID через запятую: 123456789,987654321
ADMIN_IDS=your_telegram_user_id

# Интервал постинга в часах (1.5 = каждые 1.5 часа)
POST_INTERVAL_HOURS=1.5

# Показывать превью перед публикацией? (true/false)
# true — бот присылает тебе пост на одобрение
# false — публикует автоматически без подтверждения
PREVIEW_BEFORE_POST=true
